{
  "permissions": {
    "allow": [
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(Get-ChildItem -Recurse independent-reviewer)",
      "Bash(Select-Object FullName)",
      "Bash(git check-ignore *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "WebSearch",
      "WebFetch(domain:massive.com)",
      "WebFetch(domain:polygon.io)",
      "WebFetch(domain:github.com)",
      "Bash(git fetch *)",
      "Bash(git stash *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
