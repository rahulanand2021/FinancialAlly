# OpenRouter API key for LLM chat functionality (required unless LLM_MOCK=true)
OPENROUTER_API_KEY=

# Massive (Polygon.io) API key for real market data (optional)
# Leave blank to use the built-in market simulator (recommended for most users)
MASSIVE_API_KEY=

# Set to "true" for deterministic mock LLM responses (used by E2E tests)
LLM_MOCK=false
